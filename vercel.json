{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/chat.js", "dest": "/api/index.js" },
    { "src": "/api/chat", "dest": "/api/index.js" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/", "dest": "/public/admin.html" }
  ]
}
